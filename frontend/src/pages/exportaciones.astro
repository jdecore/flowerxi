---
import '../styles/index.css';

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>flowerxi | Exportaciones</title>
  </head>
  <body>
    <main class="be-page">
      <section class="app-shell">
        <aside class="sidebar">
          <div class="sidebar-top">
            <div class="logo-mark">✿</div>
            <nav class="sidebar-nav">
              <a href="/" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M3 10.7L12 3l9 7.7M5.5 9.7V21h13V9.7"/></svg></a>
              <a href="/comparar" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M4 18h16M6 15l4-4 3 2 5-6"/><circle cx="6" cy="15" r="1.2"/><circle cx="10" cy="11" r="1.2"/><circle cx="13" cy="13" r="1.2"/><circle cx="18" cy="7" r="1.2"/></svg></a>
              <a href="/calendario" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><rect x="3.5" y="5.5" width="17" height="15" rx="2.5"/><path d="M8 3.5v4M16 3.5v4M3.5 10h17"/></svg></a>
              <a href="/municipios" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M12 21s7-5.6 7-11a7 7 0 10-14 0c0 5.4 7 11 7 11z"/><circle cx="12" cy="10" r="2.8"/></svg></a>
            </nav>
          </div>
          <div class="sidebar-bottom">
            <a href="/precios" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 100 7h7a3.5 3.5 0 110 7H6"/></svg></a>
            <a href="/exportaciones" class="sidebar-icon active"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M21 12V7H5a2 2 0 010-4h14v4M3 5v14a2 2 0 002 2h16v-5M3 12h18"/></svg></a>
          </div>
        </aside>

        <section class="main-panel">
          <header class="top-header">
            <div class="brand-block">
              <p class="brand-logo">flowerxi</p>
              <h1>Exportaciones (DANE proxy)</h1>
            </div>
          </header>

          <div id="exports-content"><p class="loading-text">Cargando...</p></div>
        </section>
      </section>
    </main>

    <script define:vars={{ apiUrl }}>
      async function load() {
        const el = document.getElementById('exports-content');
        try {
          const res = await fetch(`${apiUrl}/api/exports?months=12`);
          const data = await res.json();
          if (!data.items?.length) {
            el.innerHTML = '<p class="empty-text">Sin datos.</p>';
            return;
          }
          const s = data.summary || {};
          el.innerHTML = `
            <div class="summary-grid">
              <div class="summary-card"><span class="sum-label">Valor FOB</span><span class="sum-value">$${(s.total_fob_usd/1e6).toFixed(1)}M</span></div>
              <div class="summary-card"><span class="sum-label">Volumen</span><span class="sum-value">${(s.total_net_tons/1e3).toFixed(1)}K</span></div>
              <div class="summary-card"><span class="sum-label">Precio/kg</span><span class="sum-value">$${s.avg_price_per_kg?.toFixed(2)}</span></div>
              <div class="summary-card"><span class="sum-label">Meses</span><span class="sum-value">${s.months_count}</span></div>
            </div>
            <div class="exports-table">
              <div class="table-header"><span>Mes</span><span>Destino</span><span>FOB USD</span><span>Kg</span><span>$/kg</span></div>
              ${Object.keys(data.by_month || {}).sort().reverse().slice(0,6).map(m => `
                <div class="table-month">${m}</div>
                ${data.items.filter(i => i.year_month === m).slice(0,5).map(i => `
                  <div class="table-row">
                    <span></span><span class="dest">${i.country_dest}</span>
                    <span>$${(i.fob_usd/1e6).toFixed(2)}M</span>
                    <span>${(i.net_tons/1e3).toFixed(2)}K</span>
                    <span>$${i.unit_value}</span>
                  </div>
                `).join('')}
              `).join('')}
            </div>
          `;
        } catch (e) {
          el.innerHTML = `<p class="error-text">${e.message}</p>`;
        }
      }
      load();
    </script>

    <style>
      .summary-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.5rem; }
      .summary-card { background: linear-gradient(135deg, rgba(117,106,133,0.12), rgba(117,106,133,0.06)); border: 1px solid rgba(117,106,133,0.25); border-radius: 14px; padding: 1rem; text-align: center; }
      .sum-label { display: block; font-size: 0.75rem; color: var(--text-secondary); }
      .sum-value { display: block; font-size: 1.2rem; font-weight: 600; color: var(--primary); margin-top: 0.25rem; }
      .exports-table { background: var(--bg-surface); border: 1px solid var(--border-subtle); border-radius: 12px; overflow: hidden; }
      .table-header, .table-row, .table-month { display: grid; grid-template-columns: 1.5fr 1.5fr 1fr 1fr 0.8fr; gap: 0.5rem; padding: 0.6rem 1rem; }
      .table-header { background: var(--bg-app); font-weight: 600; font-size: 0.75rem; color: var(--primary); }
      .table-month { background: #F0EDF3; font-weight: 600; color: var(--primary); border-top: 1px solid var(--border-subtle); }
      .table-month:first-child { border-top: none; }
      .table-row { border-top: 1px solid var(--border-subtle); font-size: 0.8rem; }
      .dest { font-weight: 500; color: var(--text-primary); }
      .loading-text, .empty-text, .error-text { color: var(--text-secondary); text-align: center; padding: 2rem; }
    </style>
  </body>
</html>