---
import '../styles/index.css';

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>flowerxi | Exportaciones</title>
  </head>
  <body>
    <main class="be-page">
      <section class="app-shell">
        <aside class="sidebar">
          <div class="sidebar-top">
            <div class="logo-mark" aria-label="flowerxi">✿</div>
            <nav class="sidebar-nav" aria-label="Navegacion principal">
              <a href="/" class="sidebar-icon" aria-label="Inicio">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                  <path d="M3 10.7L12 3l9 7.7" />
                  <path d="M5.5 9.7V21h13V9.7" />
                </svg>
              </a>
              <a href="/comparar" class="sidebar-icon" aria-label="Comparar">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                  <path d="M4 18h16" />
                  <path d="M6 15l4-4 3 2 5-6" />
                  <circle cx="6" cy="15" r="1.2" />
                  <circle cx="10" cy="11" r="1.2" />
                  <circle cx="13" cy="13" r="1.2" />
                  <circle cx="18" cy="7" r="1.2" />
                </svg>
              </a>
              <a href="/calendario" class="sidebar-icon" aria-label="Calendario">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                  <rect x="3.5" y="5.5" width="17" height="15" rx="2.5" />
                  <path d="M8 3.5v4M16 3.5v4M3.5 10h17" />
                </svg>
              </a>
              <a href="/municipios" class="sidebar-icon" aria-label="Municipios">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                  <path d="M12 21s7-5.6 7-11a7 7 0 10-14 0c0 5.4 7 11 7 11z" />
                  <circle cx="12" cy="10" r="2.8" />
                </svg>
              </a>
            </nav>
          </div>
          <div class="sidebar-bottom">
            <a href="/precios" class="sidebar-icon" aria-label="Precios">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 100 7h7a3.5 3.5 0 110 7H6" />
              </svg>
            </a>
            <a href="/exportaciones" class="sidebar-icon active" aria-label="Exportaciones">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                <path d="M21 12V7H5a2 2 0 010-4h14v4M3 5v14a2 2 0 002 2h16v-5M3 12h18" />
              </svg>
            </a>
          </div>
        </aside>

        <section class="main-panel">
          <header class="top-header">
            <div class="brand-block">
              <p class="brand-logo">flowerxi</p>
              <h1>Exportaciones (DANE proxy)</h1>
            </div>
          </header>

          <section class="exports-content" id="exports-content">
            <p class="loading-text">Cargando datos...</p>
          </section>
        </section>
      </section>
    </main>

    <script define:vars={{ apiUrl }}>
      async function loadExports() {
        const container = document.getElementById('exports-content');
        try {
          const res = await fetch(`${apiUrl}/api/exports?months=12`);
          const data = await res.json();
          if (!data.items || data.items.length === 0) {
            container.innerHTML = '<p class="empty-text">No hay datos de exportaciones.</p>';
            return;
          }
          const sum = data.summary || {};
          let html = `
            <div class="exports-summary">
              <div class="summary-card">
                <span class="summary-label">Valor FOB Total</span>
                <span class="summary-value">$${(sum.total_fob_usd / 1000000).toFixed(1)}M USD</span>
              </div>
              <div class="summary-card">
                <span class="summary-label">Volumen Total</span>
                <span class="summary-value">${(sum.total_net_tons / 1000).toFixed(1)}K ton</span>
              </div>
              <div class="summary-card">
                <span class="summary-label">Precio Promedio</span>
                <span class="summary-value">$${sum.avg_price_per_kg?.toFixed(2)}/kg</span>
              </div>
              <div class="summary-card">
                <span class="summary-label">Meses</span>
                <span class="summary-value">${sum.months_count ?? '--'}</span>
              </div>
            </div>
            <div class="exports-table">
              <div class="table-header">
                <span>Mes</span>
                <span>Destino</span>
                <span>FOB USD</span>
                <span>Kg</span>
                <span>$/kg</span>
              </div>
          `;
          const byMonth = data.by_month || {};
          const sortedMonths = Object.keys(byMonth).sort().reverse().slice(0, 6);
          for (const month of sortedMonths) {
            const monthData = byMonth[month];
            html += `
              <div class="table-month">
                <span class="month-label">${month}</span>
              </div>
            `;
            const monthItems = data.items.filter(i => i.year_month === month).slice(0, 5);
            html += monthItems.map(i => `
              <div class="table-row">
                <span></span>
                <span class="dest">${i.country_dest}</span>
                <span>$${(i.fob_usd / 1000000).toFixed(2)}M</span>
                <span>${(i.net_tons / 1000).toFixed(2)}K</span>
                <span>$${i.unit_value}</span>
              </div>
            `).join('');
          }
          html += '</div>';
          container.innerHTML = html;
        } catch (e) {
          container.innerHTML = `<p class="error-text">Error: ${e.message}</p>`;
        }
      }
      loadExports();
    </script>

    <style>
      .exports-content { padding: 1rem; }
      .exports-summary {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
        margin-bottom: 1.5rem;
      }
      .summary-card {
        background: linear-gradient(135deg, rgba(107, 63, 160, 0.15), rgba(127, 57, 251, 0.1));
        border: 1px solid rgba(107, 63, 160, 0.3);
        border-radius: 14px;
        padding: 1rem;
        text-align: center;
      }
      .summary-label {
        display: block;
        font-size: 0.8rem;
        color: var(--text-muted, #6B6B6B);
      }
      .summary-value {
        display: block;
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--primary, #6B3FA0);
        margin-top: 0.25rem;
      }
      .exports-table {
        background: #fff;
        border: 1px solid #ECE3DA;
        border-radius: 12px;
        overflow: hidden;
      }
      .table-header, .table-row, .table-month {
        display: grid;
        grid-template-columns: 1.5fr 1.5fr 1fr 1fr 0.8fr;
        gap: 0.5rem;
        padding: 0.6rem 1rem;
      }
      .table-header {
        background: #F5EEF9;
        font-weight: 600;
        font-size: 0.8rem;
        color: var(--primary, #6B3FA0);
      }
      .table-month {
        background: #F0E8F5;
        font-weight: 600;
        color: var(--primary, #6B3FA0);
        border-top: 1px solid #ECE3DA;
      }
      .table-month:first-child {
        border-top: none;
      }
      .table-row {
        border-top: 1px solid #ECE3DA;
        font-size: 0.85rem;
      }
      .dest {
        font-weight: 500;
        color: var(--text, #1A1A1A);
      }
      .loading-text, .empty-text, .error-text {
        color: var(--text-muted, #6B6B6B);
        text-align: center;
        padding: 2rem;
      }
    </style>
  </body>
</html>