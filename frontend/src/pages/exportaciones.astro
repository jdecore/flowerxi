---
import ComercialDashboard from '../islands/ComercialDashboard.svelte';
import '../styles/index.css';

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>flowerxi | Comercial</title>
  </head>
  <body>
    <main class="be-page">
      <section class="app-shell">
        <aside class="sidebar">
          <div class="sidebar-top">
            <div class="logo-mark">✿</div>
            <nav class="sidebar-nav">
              <a href="/" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M3 10.7L12 3l9 7.7M5.5 9.7V21h13V9.7"/></svg></a>
              <a href="/municipios" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M12 21s7-5.6 7-11a7 7 0 10-14 0c0 5.4 7 11 7 11z"/><circle cx="12" cy="10" r="2.8"/></svg></a>
              <a href="/exportaciones" class="sidebar-icon active"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M21 12V7H5a2 2 0 010-4h14v4M3 5v14a2 2 0 002 2h16v-5M3 12h18"/></svg></a>
              <a href="/estaciones" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v4M12 18v4M2 12h4M18 12h4"/></svg></a>
            </nav>
          </div>
          <div class="sidebar-bottom">
            <button class="sidebar-icon chat-toggle" aria-label="Chat AI">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            </button>
          </div>
        </aside>

        <section class="main-panel">
          <header class="top-header">
            <div class="brand-block">
              <p class="brand-logo">flowerxi</p>
              <h1>Comercial: Exportaciones y Precios</h1>
            </div>
          </header>

          <ComercialDashboard apiUrl={apiUrl} client:load />
        </section>
      </section>
    </main>
  </body>
</html>