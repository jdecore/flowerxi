---
import '../styles/index.css';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>flowerxi | Calendario</title>
  </head>
  <body>
    <main class="be-page">
      <section class="app-shell">
        <aside class="sidebar">
          <div class="sidebar-top">
            <div class="logo-mark">✿</div>
            <nav class="sidebar-nav">
              <a href="/" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M3 10.7L12 3l9 7.7M5.5 9.7V21h13V9.7"/></svg></a>
              <a href="/comparar" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M4 18h16M6 15l4-4 3 2 5-6"/><circle cx="6" cy="15" r="1.2"/><circle cx="10" cy="11" r="1.2"/><circle cx="13" cy="13" r="1.2"/><circle cx="18" cy="7" r="1.2"/></svg></a>
              <a href="/calendario" class="sidebar-icon active"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><rect x="3.5" y="5.5" width="17" height="15" rx="2.5"/><path d="M8 3.5v4M16 3.5v4M3.5 10h17"/></svg></a>
              <a href="/municipios" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M12 21s7-5.6 7-11a7 7 0 10-14 0c0 5.4 7 11 7 11z"/><circle cx="12" cy="10" r="2.8"/></svg></a>
            </nav>
          </div>
          <div class="sidebar-bottom">
            <a href="/precios" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 100 7h7a3.5 3.5 0 110 7H6"/></svg></a>
            <a href="/exportaciones" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M21 12V7H5a2 2 0 010-4h14v4M3 5v14a2 2 0 002 2h16v-5M3 12h18"/></svg></a>
          </div>
        </aside>

        <section class="main-panel">
          <header class="top-header">
            <div class="brand-block">
              <p class="brand-logo">flowerxi</p>
              <h1>Calendario de Alertas</h1>
            </div>
          </header>

          <div class="calendar-placeholder">
            <p>El calendario de alertas se muestra en el dashboard principal.</p>
            <a href="/" class="btn-dashboard">Ver Dashboard &rarr;</a>
          </div>
        </section>
      </section>
    </main>

    <style>
      .calendar-placeholder { text-align: center; padding: 3rem 2rem; background: var(--bg-app); border-radius: 16px; }
      .calendar-placeholder p { color: var(--text-secondary); margin-bottom: 1.5rem; }
      .btn-dashboard { display: inline-block; padding: 0.75rem 1.5rem; background: var(--primary); color: white; border-radius: 999px; text-decoration: none; font-weight: 500; transition: background 160ms; }
      .btn-dashboard:hover { background: var(--primary-hover); }
    </style>
  </body>
</html>