---
import '../styles/index.css';

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>flowerxi | Calendario</title>
  </head>
  <body>
    <main class="be-page">
      <section class="app-shell">
        <aside class="sidebar">
          <div class="sidebar-top">
            <div class="logo-mark">✿</div>
            <nav class="sidebar-nav">
              <a href="/" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M3 10.7L12 3l9 7.7M5.5 9.7V21h13V9.7"/></svg></a>
              <a href="/comparar" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M4 18h16M6 15l4-4 3 2 5-6"/><circle cx="6" cy="15" r="1.2"/><circle cx="10" cy="11" r="1.2"/><circle cx="13" cy="13" r="1.2"/><circle cx="18" cy="7" r="1.2"/></svg></a>
              <a href="/calendario" class="sidebar-icon active"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><rect x="3.5" y="5.5" width="17" height="15" rx="2.5"/><path d="M8 3.5v4M16 3.5v4M3.5 10h17"/></svg></a>
              <a href="/municipios" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M12 21s7-5.6 7-11a7 7 0 10-14 0c0 5.4 7 11 7 11z"/><circle cx="12" cy="10" r="2.8"/></svg></a>
              <a href="/estaciones" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v4M12 18v4M2 12h4M18 12h4"/></svg></a>
            </nav>
          </div>
          <div class="sidebar-bottom">
            <a href="/precios" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 100 7h7a3.5 3.5 0 110 7H6"/></svg></a>
            <a href="/exportaciones" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M21 12V7H5a2 2 0 010-4h14v4M3 5v14a2 2 0 002 2h16v-5M3 12h18"/></svg></a>
          </div>
        </aside>

        <section class="main-panel">
          <header class="top-header">
            <div class="brand-block">
              <p class="brand-logo">flowerxi</p>
              <h1>Calendario y Feriados</h1>
            </div>
          </header>

          <section class="calendar-page">
            <div class="calendar-controls">
              <button class="year-btn" id="prev-year">&larr; 2025</button>
              <span class="year-label">2026</span>
              <button class="year-btn" id="next-year">2027 &rarr;</button>
            </div>
            <div class="holidays-list" id="holidays-list">
              <p class="loading">Cargando feriados...</p>
            </div>
          </section>
        </section>
      </section>
    </main>

    <script define:vars={{ apiUrl }}>
      const COLORS = {
        primary: '#756A85',
        bg: '#F6F4F8',
        text: '#2B2730',
        muted: '#6B6573',
        border: '#E5E0EB',
      };

      async function loadHolidays(year = 2026) {
        const el = document.getElementById('holidays-list');
        try {
          const res = await fetch(`${apiUrl}/api/calendar?year=${year}`);
          const data = await res.json();
          if (!data.items?.length) {
            el.innerHTML = '<p class="empty">No hay feriados registrados para ' + year + '</p>';
            return;
          }
          el.innerHTML = data.items.map(h => `
            <div class="holiday-card">
              <div class="holiday-date">${new Date(h.event_date).toLocaleDateString('es-CO', {day:'numeric', month:'long'})}</div>
              <div class="holiday-name">${h.event_name}</div>
              ${h.local_name ? `<div class="holiday-local">${h.local_name}</div>` : ''}
            </div>
          `).join('');
        } catch (e) {
          el.innerHTML = '<p class="error">Error: ' + e.message + '</p>';
        }
      }

      document.getElementById('prev-year').onclick = () => loadHolidays(2025);
      document.getElementById('next-year').onclick = () => loadHolidays(2027);
      loadHolidays(2026);
    </script>

    <style>
      .calendar-page { padding: 0.5rem 0; }
      .calendar-controls { display: flex; align-items: center; justify-content: center; gap: 1.5rem; margin-bottom: 1.5rem; }
      .year-btn { background: var(--bg-surface); border: 1px solid var(--border-subtle); border-radius: 8px; padding: 0.5rem 1rem; color: var(--text-primary); cursor: pointer; }
      .year-btn:hover { background: var(--primary); color: white; }
      .year-label { font-size: 1.5rem; font-weight: 600; color: var(--primary); }
      .holidays-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 0.75rem; }
      .holiday-card { background: var(--bg-surface); border: 1px solid var(--border-subtle); border-radius: 12px; padding: 1rem; }
      .holiday-date { font-size: 0.85rem; color: var(--primary); font-weight: 600; }
      .holiday-name { font-size: 1rem; color: var(--text-primary); margin-top: 0.25rem; }
      .holiday-local { font-size: 0.8rem; color: var(--text-secondary); font-style: italic; margin-top: 0.25rem; }
      .loading, .empty, .error { color: var(--text-secondary); text-align: center; padding: 2rem; }
      .error { color: #C75D5D; }
    </style>
  </body>
</html>