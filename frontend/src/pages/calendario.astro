---
import '../styles/index.css';

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>flowerxi | Calendario</title>
  </head>
  <body>
    <main class="be-page">
      <section class="app-shell">
        <aside class="sidebar">
          <div class="sidebar-top">
            <div class="logo-mark" aria-label="flowerxi">✿</div>
            <nav class="sidebar-nav" aria-label="Navegacion principal">
              <a href="/" class="sidebar-icon" aria-label="Inicio">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                  <path d="M3 10.7L12 3l9 7.7" />
                  <path d="M5.5 9.7V21h13V9.7" />
                </svg>
              </a>
              <a href="/comparar" class="sidebar-icon" aria-label="Comparar">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                  <path d="M4 18h16" />
                  <path d="M6 15l4-4 3 2 5-6" />
                  <circle cx="6" cy="15" r="1.2" />
                  <circle cx="10" cy="11" r="1.2" />
                  <circle cx="13" cy="13" r="1.2" />
                  <circle cx="18" cy="7" r="1.2" />
                </svg>
              </a>
              <a href="/calendario" class="sidebar-icon active" aria-label="Calendario">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                  <rect x="3.5" y="5.5" width="17" height="15" rx="2.5" />
                  <path d="M8 3.5v4M16 3.5v4M3.5 10h17" />
                </svg>
              </a>
              <a href="/municipios" class="sidebar-icon" aria-label="Municipios">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                  <path d="M12 21s7-5.6 7-11a7 7 0 10-14 0c0 5.4 7 11 7 11z" />
                  <circle cx="12" cy="10" r="2.8" />
                </svg>
              </a>
            </nav>
          </div>
          <div class="sidebar-bottom">
            <a href="/precios" class="sidebar-icon" aria-label="Precios">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 100 7h7a3.5 3.5 0 110 7H6" />
              </svg>
            </a>
            <a href="/exportaciones" class="sidebar-icon" aria-label="Exportaciones">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                <path d="M21 12V7H5a2 2 0 010-4h14v4M3 5v14a2 2 0 002 2h16v-5M3 12h18" />
              </svg>
            </a>
          </div>
        </aside>

        <section class="main-panel">
          <header class="top-header">
            <div class="brand-block">
              <p class="brand-logo">flowerxi</p>
              <h1>Calendario de Alertas</h1>
            </div>
          </header>

          <section class="calendar-content" id="calendar-content">
            <p class="info-text">El calendario de alertas muestra el historial de riesgos diarios por municipio.</p>
            <div class="calendar-placeholder">
              <p>Usa el calendario en el dashboard principal para ver el mes actual.</p>
              <a href="/" class="link-btn">Ver Dashboard</a>
            </div>
          </section>
        </section>
      </section>
    </main>

    <style>
      .calendar-content { padding: 1rem; }
      .info-text {
        margin-bottom: 1rem;
        color: var(--text-muted, #6B6B6B);
      }
      .calendar-placeholder {
        background: #FAF7F3;
        border-radius: 16px;
        padding: 2rem;
        text-align: center;
      }
      .link-btn {
        display: inline-block;
        margin-top: 1rem;
        padding: 0.5rem 1rem;
        background: var(--primary, #6B3FA0);
        color: #fff;
        border-radius: 8px;
        text-decoration: none;
      }
    </style>
  </body>
</html>