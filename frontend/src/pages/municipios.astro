---
import '../styles/index.css';

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>flowerxi | Municipios</title>
  </head>
  <body>
    <main class="be-page">
      <section class="app-shell">
        <aside class="sidebar">
          <div class="sidebar-top">
            <div class="logo-mark" aria-label="flowerxi">✿</div>
            <nav class="sidebar-nav">
              <a href="/" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M3 10.7L12 3l9 7.7M5.5 9.7V21h13V9.7"/></svg></a>
              <a href="/municipios" class="sidebar-icon active"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M12 21s7-5.6 7-11a7 7 0 10-14 0c0 5.4 7 11 7 11z"/><circle cx="12" cy="10" r="2.8"/></svg></a>
              <a href="/exportaciones" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M21 12V7H5a2 2 0 010-4h14v4M3 5v14a2 2 0 002 2h16v-5M3 12h18"/></svg></a>
              <a href="/estaciones" class="sidebar-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v4M12 18v4M2 12h4M18 12h4"/></svg></a>
            </nav>
          </div>
          <div class="sidebar-bottom">
            <button class="sidebar-icon chat-toggle" aria-label="Chat AI">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            </button>
          </div>
        </aside>

        <section class="main-panel">
          <header class="top-header">
            <div class="brand-block">
              <p class="brand-logo">flowerxi</p>
              <h1>Perfiles Municipales</h1>
            </div>
          </header>

          <div class="content-grid">
            <div class="municipios-list" id="municipios-list">
              <p class="loading-text">Cargando perfiles...</p>
            </div>
            <div class="municipio-detail" id="municipio-detail" style="display: none;">
              <button class="back-btn" onclick="showList()">&larr; Volver</button>
              <div id="detail-content"></div>
            </div>
          </div>
        </section>
      </section>
    </main>

    <script define:vars={{ apiUrl }}>
      async function loadMunicipios() {
        const el = document.getElementById('municipios-list');
        try {
          const res = await fetch(`${apiUrl}/api/municipalities`);
          const data = await res.json();
          if (!data.items?.length) {
            el.innerHTML = '<p class="empty-text">No hay perfiles disponibles.</p>';
            return;
          }
          el.innerHTML = data.items.map(m => `
            <article class="muni-card" onclick="showDetail('${m.slug}')">
              <h3>${m.name}</h3>
              <p class="muted">${m.city}, ${m.department}</p>
              <div class="muni-stats">
                <span>${m.flower_area_ha ?? '--'} ha</span>
                <span>${m.greenhouse_area_ha ?? '--'} ha</span>
                <span>${m.workers ?? '--'} workers</span>
              </div>
            </article>
          `).join('');
        } catch (e) {
          el.innerHTML = `<p class="error-text">${e.message}</p>`;
        }
      }

      async function showDetail(slug) {
        const detailEl = document.getElementById('municipio-detail');
        const contentEl = document.getElementById('detail-content');
        const listEl = document.getElementById('municipios-list');
        listEl.style.display = 'none';
        detailEl.style.display = 'block';
        contentEl.innerHTML = '<p>Cargando...</p>';
        try {
          const res = await fetch(`${apiUrl}/api/municipalities/${slug}`);
          const data = await res.json();
          const m = data.item || {};
          contentEl.innerHTML = `
            <h2>${m.name}</h2>
            <p class="muted">${m.city}, ${m.department}</p>
            <div class="stats-grid">
              <div class="stat-box"><span class="stat-label">Área flor</span><span class="stat-value">${m.flower_area_ha ?? '--'} ha</span></div>
              <div class="stat-box"><span class="stat-label">Invernadero</span><span class="stat-value">${m.greenhouse_area_ha ?? '--'} ha</span></div>
              <div class="stat-box"><span class="stat-label">Trabajadores</span><span class="stat-value">${m.workers ?? '--'}</span></div>
              <div class="stat-box"><span class="stat-label">Mujeres</span><span class="stat-value">${m.workers_female ?? '--'}</span></div>
              <div class="stat-box"><span class="stat-label">Hombres</span><span class="stat-value">${m.workers_male ?? '--'}</span></div>
            </div>
            <div class="context-box">
              <h4>Contexto Fitosanitario</h4><p>${m.fisanicitary_context || 'Sin info'}</p>
              <h4>Gestión de Residuos</h4><p>${m.waste_management || 'Sin info'}</p>
              <h4>Variedades Principales</h4><p>${Array.isArray(m.main_varieties) ? m.main_varieties.join(', ') : 'Sin info'}</p>
            </div>
          `;
        } catch (e) {
          contentEl.innerHTML = `<p class="error-text">${e.message}</p>`;
        }
      }

      function showList() {
        document.getElementById('municipios-list').style.display = 'grid';
        document.getElementById('municipio-detail').style.display = 'none';
      }
      window.showDetail = showDetail;
      window.showList = showList;
      loadMunicipios();
    </script>

    <style>
      .content-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; }
      .muni-card { background: var(--bg-surface); border: 1px solid var(--border-subtle); border-radius: 16px; padding: 1.25rem; cursor: pointer; transition: all 160ms; }
      .muni-card:hover { border-color: var(--primary); box-shadow: var(--shadow-md); }
      .muni-card h3 { margin: 0; color: var(--primary); font-size: 1rem; }
      .muni-card .muted { margin: 0.25rem 0 0.75rem; font-size: 0.85rem; color: var(--text-secondary); }
      .muni-stats { display: flex; gap: 0.5rem; font-size: 0.75rem; }
      .muni-stats span { background: var(--bg-app); padding: 0.25rem 0.5rem; border-radius: 6px; color: var(--text-secondary); }
      .municipio-detail { max-width: 700px; }
      .back-btn { background: none; border: none; color: var(--primary); cursor: pointer; font-size: 0.9rem; margin-bottom: 1rem; }
      .back-btn:hover { color: var(--primary-hover); }
      .stats-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.75rem; margin: 1rem 0; }
      .stat-box { background: var(--bg-app); padding: 0.75rem; border-radius: 10px; text-align: center; }
      .stat-label { display: block; font-size: 0.7rem; color: var(--text-secondary); }
      .stat-value { display: block; font-size: 1.1rem; font-weight: 600; color: var(--primary); margin-top: 0.25rem; }
      .context-box { margin-top: 1.5rem; padding: 1rem; background: var(--bg-app); border-radius: 12px; }
      .context-box h4 { margin: 1rem 0 0.5rem; color: var(--primary); font-size: 0.85rem; }
      .context-box h4:first-child { margin-top: 0; }
      .context-box p { margin: 0; font-size: 0.9rem; color: var(--text-primary); }
      .loading-text, .empty-text, .error-text { color: var(--text-secondary); text-align: center; padding: 2rem; }
      .error-text { color: #C75D5D; }
    </style>
  </body>
</html>