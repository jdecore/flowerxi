---
import '../styles/index.css';

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>flowerxi | Municipios</title>
  </head>
  <body>
    <main class="be-page">
      <section class="app-shell">
        <aside class="sidebar">
          <div class="sidebar-top">
            <div class="logo-mark" aria-label="flowerxi">✿</div>
            <nav class="sidebar-nav" aria-label="Navegacion principal">
              <a href="/" class="sidebar-icon" aria-label="Inicio">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                  <path d="M3 10.7L12 3l9 7.7" />
                  <path d="M5.5 9.7V21h13V9.7" />
                </svg>
              </a>
              <a href="/comparar" class="sidebar-icon" aria-label="Comparar">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                  <path d="M4 18h16" />
                  <path d="M6 15l4-4 3 2 5-6" />
                  <circle cx="6" cy="15" r="1.2" />
                  <circle cx="10" cy="11" r="1.2" />
                  <circle cx="13" cy="13" r="1.2" />
                  <circle cx="18" cy="7" r="1.2" />
                </svg>
              </a>
              <a href="/calendario" class="sidebar-icon" aria-label="Calendario">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                  <rect x="3.5" y="5.5" width="17" height="15" rx="2.5" />
                  <path d="M8 3.5v4M16 3.5v4M3.5 10h17" />
                </svg>
              </a>
              <a href="/municipios" class="sidebar-icon active" aria-label="Municipios">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                  <path d="M12 21s7-5.6 7-11a7 7 0 10-14 0c0 5.4 7 11 7 11z" />
                  <circle cx="12" cy="10" r="2.8" />
                </svg>
              </a>
            </nav>
          </div>
          <div class="sidebar-bottom">
            <a href="/precios" class="sidebar-icon" aria-label="Precios">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 100 7h7a3.5 3.5 0 110 7H6" />
              </svg>
            </a>
            <a href="/exportaciones" class="sidebar-icon" aria-label="Exportaciones">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                <path d="M21 12V7H5a2 2 0 010-4h14v4M3 5v14a2 2 0 002 2h16v-5M3 12h18" />
              </svg>
            </a>
          </div>
        </aside>

        <section class="main-panel">
          <header class="top-header">
            <div class="brand-block">
              <p class="brand-logo">flowerxi</p>
              <h1>Perfiles Municipales</h1>
            </div>
          </header>

          <section class="municipios-content">
            <div class="municipios-list" id="municipios-list">
              <p class="loading-text">Cargando perfiles...</p>
            </div>

            <div class="municipio-detail" id="municipio-detail" style="display: none;">
              <button class="back-btn" onclick="showList()">&larr; Volver</button>
              <div id="detail-content"></div>
            </div>
          </section>
        </section>
      </section>
    </main>

    <script define:vars={{ apiUrl }}>
      async function loadMunicipios() {
        const listEl = document.getElementById('municipios-list');
        try {
          const res = await fetch(`${apiUrl}/api/municipalities`);
          const data = await res.json();
          if (!data.items || data.items.length === 0) {
            listEl.innerHTML = '<p class="empty-text">No hay perfiles municipales disponibles.</p>';
            return;
          }
          listEl.innerHTML = data.items.map(m => `
            <article class="municipio-card" onclick="showDetail('${m.slug}')">
              <h3>${m.name}</h3>
              <p class="muted">${m.city}, ${m.department}</p>
              <div class="municipio-stats">
                <span>${m.flower_area_ha || '--'} ha flores</span>
                <span>${m.greenhouse_area_ha || '--'} ha invernadero</span>
                <span>${m.workers || '--'} trabajadores</span>
              </div>
            </article>
          `).join('');
        } catch (e) {
          listEl.innerHTML = `<p class="error-text">Error: ${e.message}</p>`;
        }
      }

      async function showDetail(slug) {
        const detailEl = document.getElementById('municipio-detail');
        const contentEl = document.getElementById('detail-content');
        const listEl = document.getElementById('municipios-list');
        listEl.style.display = 'none';
        detailEl.style.display = 'block';
        contentEl.innerHTML = '<p class="loading-text">Cargando...</p>';
        try {
          const res = await fetch(`${apiUrl}/api/municipalities/${slug}`);
          const data = await res.json();
          if (!data.item) {
            contentEl.innerHTML = '<p class="error-text">Municipio no encontrado</p>';
            return;
          }
          const m = data.item;
          contentEl.innerHTML = `
            <h2>${m.name}</h2>
            <p class="muted">${m.city}, ${m.department}</p>
            <div class="detail-stats">
              <div class="stat-block">
                <span class="stat-label">Area flor</span>
                <span class="stat-value">${m.flower_area_ha ?? '--'} ha</span>
              </div>
              <div class="stat-block">
                <span class="stat-label">Invernadero</span>
                <span class="stat-value">${m.greenhouse_area_ha ?? '--'} ha</span>
              </div>
              <div class="stat-block">
                <span class="stat-label">Trabajadores</span>
                <span class="stat-value">${m.workers ?? '--'}</span>
              </div>
              <div class="stat-block">
                <span class="stat-label">Mujeres</span>
                <span class="stat-value">${m.workers_female ?? '--'}</span>
              </div>
              <div class="stat-block">
                <span class="stat-label">Hombres</span>
                <span class="stat-value">${m.workers_male ?? '--'}</span>
              </div>
            </div>
            <div class="detail-context">
              <h4>Contexto Fitosanitario</h4>
              <p>${m.fisanicitary_context ?? 'Sin información'}</p>
              <h4>Gestion de Residuos</h4>
              <p>${m.waste_management ?? 'Sin información'}</p>
              <h4>Variedades Principales</h4>
              <p>${Array.isArray(m.main_varieties) ? m.main_varieties.join(', ') : 'Sin información'}</p>
            </div>
          `;
        } catch (e) {
          contentEl.innerHTML = `<p class="error-text">Error: ${e.message}</p>`;
        }
      }

      function showList() {
        document.getElementById('municipios-list').style.display = 'grid';
        document.getElementById('municipio-detail').style.display = 'none';
      }

      window.showDetail = showDetail;
      window.showList = showList;
      loadMunicipios();
    </script>

    <style>
      .municipios-content {
        padding: 1rem;
      }
      .municipios-list {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1rem;
      }
      .municipio-card {
        background: var(--card-bg, #fff);
        border: 1px solid #ECE3DA;
        border-radius: 16px;
        padding: 1rem;
        cursor: pointer;
        transition: box-shadow 0.2s;
      }
      .municipio-card:hover {
        box-shadow: 0 4px 12px rgba(107, 63, 160, 0.15);
      }
      .municipio-card h3 {
        margin: 0;
        color: var(--primary, #6B3FA0);
      }
      .municipio-card .muted {
        margin: 0.25rem 0 0;
        color: var(--text-muted, #6B6B6B);
        font-size: 0.85rem;
      }
      .municipio-stats {
        display: flex;
        gap: 0.75rem;
        margin-top: 0.75rem;
        font-size: 0.8rem;
        color: var(--text-muted, #6B6B6B);
      }
      .municipio-stats span {
        background: #F5EEF9;
        padding: 0.2rem 0.5rem;
        border-radius: 6px;
      }
      .municipio-detail {
        max-width: 700px;
      }
      .back-btn {
        background: none;
        border: none;
        color: var(--primary, #6B3FA0);
        cursor: pointer;
        font-size: 0.9rem;
        margin-bottom: 1rem;
      }
      .detail-stats {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 0.75rem;
        margin: 1rem 0;
      }
      .stat-block {
        background: #F5EEF9;
        padding: 0.75rem;
        border-radius: 10px;
        text-align: center;
      }
      .stat-label {
        display: block;
        font-size: 0.75rem;
        color: var(--text-muted, #6B6B6B);
      }
      .stat-value {
        display: block;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--primary, #6B3FA0);
        margin-top: 0.25rem;
      }
      .detail-context {
        margin-top: 1.5rem;
        padding: 1rem;
        background: #FAF7F3;
        border-radius: 12px;
      }
      .detail-context h4 {
        margin: 1rem 0 0.5rem;
        color: var(--primary, #6B3FA0);
        font-size: 0.9rem;
      }
      .detail-context h4:first-child {
        margin-top: 0;
      }
      .detail-context p {
        margin: 0;
        color: var(--text, #1A1A1A);
        font-size: 0.9rem;
      }
      .loading-text, .empty-text, .error-text {
        color: var(--text-muted, #6B6B6B);
        text-align: center;
        padding: 2rem;
      }
      .error-text {
        color: #B42318;
      }
    </style>
  </body>
</html>