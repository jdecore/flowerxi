---
import Dashboard from '../components/Dashboard.svelte';
import ChatBot from '../islands/ChatBot.svelte';
import '../styles/index.css';

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>flowerxi | Estado de Cultivo</title>
  </head>
  <body>
    <main class="be-page">
      <section class="app-shell">
        <aside class="sidebar">
          <div class="sidebar-top">
            <div class="logo-mark" aria-label="flowerxi">✿</div>
            <nav class="sidebar-nav" aria-label="Navegacion principal">
              <a href="/" class="sidebar-icon active" aria-label="Inicio">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke="currentColor" aria-hidden="true">
                  <path d="M3 10.7L12 3l9 7.7" />
                  <path d="M5.5 9.7V21h13V9.7" />
                </svg>
              </a>
              <a href="/comparar" class="sidebar-icon" aria-label="Comparar">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke="currentColor" aria-hidden="true">
                  <path d="M4 18h16" />
                  <path d="M6 15l4-4 3 2 5-6" />
                  <circle cx="6" cy="15" r="1.2" />
                  <circle cx="10" cy="11" r="1.2" />
                  <circle cx="13" cy="13" r="1.2" />
                  <circle cx="18" cy="7" r="1.2" />
                </svg>
              </a>
              <a href="/calendario" class="sidebar-icon" aria-label="Calendario">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke="currentColor" aria-hidden="true">
                  <rect x="3.5" y="5.5" width="17" height="15" rx="2.5" />
                  <path d="M8 3.5v4M16 3.5v4M3.5 10h17" />
                </svg>
              </a>
              <a href="/municipios" class="sidebar-icon" aria-label="Municipios">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke="currentColor" aria-hidden="true">
                  <path d="M12 21s7-5.6 7-11a7 7 0 10-14 0c0 5.4 7 11 7 11z" />
                  <circle cx="12" cy="10" r="2.8" />
                </svg>
              </a>
              <a href="/estaciones" class="sidebar-icon" aria-label="Estaciones">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke="currentColor" aria-hidden="true">
                  <circle cx="12" cy="12" r="3" />
                  <path d="M12 2v4M12 18v4M2 12h4M18 12h4" />
                </svg>
              </a>
            </nav>
          </div>
          <div class="sidebar-bottom">
            <a href="/precios" class="sidebar-icon" aria-label="Precios">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 100 7h7a3.5 3.5 0 110 7H6" />
              </svg>
            </a>
            <a href="/exportaciones" class="sidebar-icon" aria-label="Exportaciones">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path d="M21 12V7H5a2 2 0 010-4h14v4M3 5v14a2 2 0 002 2h16v-5M3 12h18" />
              </svg>
            </a>
          </div>
        </aside>

        <section class="main-panel">
          <header class="top-header">
            <div class="brand-block">
              <p class="brand-logo">flowerxi</p>
              <h1>Hola, cultivador. Veamos el estado de tu roseal hoy</h1>
            </div>
            <div class="header-actions">
              <label class="search-box" for="region-search">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                  <circle cx="11" cy="11" r="6" />
                  <path d="M20 20l-4.2-4.2" />
                </svg>
                <input id="region-search" type="search" placeholder="Buscar municipio..." autocomplete="off" />
              </label>
              <button id="refresh-dashboard" class="refresh-btn" type="button">Actualizar datos</button>
            </div>
          </header>

          <Dashboard apiUrl={apiUrl} client:load />
        </section>
      </section>
      <ChatBot client:idle />
    </main>

    <script is:inline>
      (() => {
        const searchInput = document.getElementById('region-search');
        const refreshButton = document.getElementById('refresh-dashboard');
        let searchDebounce;

        const emit = (name, detail = {}) => {
          window.dispatchEvent(new CustomEvent(name, { detail }));
        };

        if (searchInput) {
          searchInput.addEventListener('input', (event) => {
            const value = event.target instanceof HTMLInputElement ? event.target.value : '';
            window.clearTimeout(searchDebounce);
            searchDebounce = window.setTimeout(() => {
              emit('flowerxi:search-region', { query: value });
            }, 220);
          });

          searchInput.addEventListener('keydown', (event) => {
            if (event.key === 'Enter') {
              event.preventDefault();
              emit('flowerxi:search-region', { query: searchInput.value });
            }
          });
        }

        if (refreshButton) {
          refreshButton.addEventListener('click', () => emit('flowerxi:refresh'));
        }
      })();
    </script>
  </body>
</html>
