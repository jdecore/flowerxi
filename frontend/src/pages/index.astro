---
import Dashboard from '../components/Dashboard.svelte';
import ChatBot from '../islands/ChatBot.svelte';

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>flowerxi | Flores de Corte Inteligentes</title>
    <style>
      :root {
        --bg: #D8C2A4;
        --text: #2E2E2E;
        --text-light: #3D3D3D;
        --muted: #5A4A3A;
        --primary: #5B3A8E;
        --primary-soft: #6F52A3;
        --primary-dark: #3E2764;
        --accent: #C69214;
        --accent-hover: #A87E10;
      }

      body {
        margin: 0;
        font-family: Inter, system-ui, Arial, sans-serif;
        color: var(--text);
        background: var(--bg);
        min-height: 100vh;
      }

      .wrapper {
        max-width: 1080px;
        margin: 0 auto;
        padding: 2rem 1rem 3rem;
      }

      .hero {
        background: linear-gradient(135deg, var(--primary), var(--primary-soft));
        border: 2px solid rgba(75, 46, 131, 0.3);
        border-radius: 20px;
        padding: 1.25rem 1.1rem;
        margin-bottom: 1.2rem;
      }

      .hero h1 {
        margin: 0 0 0.55rem;
        font-size: clamp(1.7rem, 4vw, 2.5rem);
        color: #F5F5F5;
      }

      .hero p {
        margin: 0;
        color: #D4C4E8;
      }

      .hero-actions {
        margin-top: 1rem;
      }

      .hero-actions a {
        display: inline-block;
        text-decoration: none;
        color: #F5F5F5;
        border: none;
        border-radius: 999px;
        padding: 0.5rem 0.9rem;
        background: var(--accent);
        font-size: 0.9rem;
        font-weight: 600;
      }

      .hero-actions a:hover {
        background: var(--accent-hover);
      }
    </style>
  </head>
  <body>
    <main class="wrapper">
      <section class="hero">
        <h1>Toma decisiones diarias para tu cultivo de rosa con IA</h1>
        <p>
          Monitoreo de riesgo climatico y recomendaciones accionables para rosa de corte en la Sabana de Bogota.
        </p>
        <div class="hero-actions">
          <a href="#recomendaciones">Ver recomendaciones de hoy</a>
        </div>
      </section>

      <Dashboard apiUrl={apiUrl} client:load />
      <ChatBot client:idle />
    </main>
  </body>
</html>
