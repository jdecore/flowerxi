---
import '../styles/index.css';
import '../styles/typography.css';

// Componentes
import StartupRegionModal from '../islands/StartupRegionModal.svelte';
import OperationalHero from '../islands/OperationalHero.svelte';
import EvidenceSparklines from '../islands/EvidenceSparklines.svelte';
import CommercialIntelCard from '../islands/CommercialIntelCard.svelte';
import SabanaComparison from '../islands/SabanaComparison.svelte';
import ClosestStationFooter from '../islands/ClosestStationFooter.svelte';
import RiskHeatmap from '../components/RiskHeatmap.svelte';
import ImpactoOperacion from '../components/ImpactoOperacion.svelte';
import ChatBot from '../islands/ChatBot.svelte';

const apiUrl = import.meta.env.PUBLIC_API_URL ?? '';
const normalizedApiUrl = String(apiUrl ?? '').trim().replace(/\/+$/, '');
let preconnectApiOrigin = '';
if (normalizedApiUrl.startsWith('http://') || normalizedApiUrl.startsWith('https://')) {
  try {
    preconnectApiOrigin = new URL(normalizedApiUrl).origin;
  } catch {
    preconnectApiOrigin = '';
  }
}
---
<html lang="es">
   <head>
     <meta charset="utf-8" />
     <meta name="viewport" content="width=device-width, initial-scale=1" />
     <title>flowerxi | Dashboard Agroclimático</title>
     {preconnectApiOrigin && <link rel="preconnect" href={preconnectApiOrigin} crossorigin />}
     <link rel="preconnect" href="https://fonts.googleapis.com">
     <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
     <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&display=swap" rel="stylesheet">
   </head>
  <body>
    <div class="app-root">
      <!-- Topbar -->
      <header class="topbar">
        <div class="topbar-start">
          <div class="brand">🌺 flowerxi</div>
        </div>

        <div class="topbar-center">
          <p class="topbar-status">Monitoreo operativo de riesgo fitosanitario</p>
        </div>
         <div class="topbar-end">
           <button class="btn-icon" id="btn-chat" title="Abrir chat IA">
             <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M21 15a4 4 0 01-4 4H8l-5 3V7a4 4 0 014-4h10a4 4 0 014 4z"/></svg>
           </button>
           <button class="btn-icon" id="btn-refresh" title="Actualizar">
             <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M23 4v6h-6M1 20v-6h6"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg>
           </button>
           <button class="btn-icon" id="btn-theme" title="Modo oscuro">
             <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
           </button>
         </div>
      </header>

      <StartupRegionModal {apiUrl} client:load />
      <section class="region-priority">
        <div class="region-info-left">
          <p class="region-current-label">Municipio actual</p>
          <p class="region-current-value" id="current-region">Madrid</p>
        </div>
        <button class="region-priority-btn" type="button" data-region-trigger>
          Cambiar municipio
        </button>
      </section>

      <!-- Layout principal -->
      <div class="main-layout">
        <main class="main-col">
          <section class="hero-shell">
            <p class="hero-shell-kicker">🌹 Flowerxi operativo</p>
            <p class="hero-shell-sub">Lectura en tiempo real para el municipio actual.</p>
            <OperationalHero {apiUrl} initialRegion="madrid" client:load />
          </section>

          <!-- Grid 12 columnas -->
          <div class="dashboard-12">
            <!-- Evidencia en vivo (8 cols) -->
            <section class="col-8">
              <h2 class="section-head">Evidencia en vivo</h2>
              <p class="section-sub">Últimos 14 días por municipio activo</p>
              <EvidenceSparklines {apiUrl} initialRegion="madrid" client:load />
            </section>

            <!-- Chat operativo (4 cols) -->
            <aside class="col-4">
              <h2 class="section-head">Chat IA operativo</h2>
              <ChatBot {apiUrl} embedded={true} client:idle />
            </aside>
          </div>

          <!-- Calendario ampliado -->
          <div class="one-col-row">
            <RiskHeatmap {apiUrl} region="madrid" client:visible />
          </div>

          <!-- Fila de negocio -->
          <div class="two-col-row">
            <ImpactoOperacion {apiUrl} region="madrid" client:visible />
            <CommercialIntelCard {apiUrl} initialRegion="madrid" client:visible />
          </div>

          <!-- Contexto Sabana -->
          <div class="one-col-row">
            <section class="comparison-card">
              <h3 class="section-head">Comparativa Sabana</h3>
              <SabanaComparison {apiUrl} initialRegion="madrid" client:visible />
            </section>
          </div>

          <div class="one-col-row station-row">
            <section class="station-card">
              <h3 class="section-head">Estación de referencia</h3>
              <ClosestStationFooter {apiUrl} initialRegion="madrid" client:visible />
              <p class="made-by">Hecho por Juan Enriquez- 2026</p>
            </section>
          </div>
        </main>
      </div>

      <!-- Scripts vanilla para tema y refresh -->
      <script>
        if (typeof window !== 'undefined') {
          // Toggle modo oscuro
          (function() {
            const btn = document.getElementById('btn-theme');
            const root = document.documentElement;
            const saved = localStorage.getItem('darkMode') === 'true';
            if (saved) root.setAttribute('data-theme', 'dark');

            btn.addEventListener('click', () => {
              const isDark = root.getAttribute('data-theme') === 'dark';
              root.setAttribute('data-theme', isDark ? 'light' : 'dark');
              localStorage.setItem('darkMode', !isDark);
            });
          })();

          // Abrir selector de municipio
          const openRegionSelector = () => {
            window.dispatchEvent(new Event('open-region-selector'));
          };
          document.querySelectorAll('[data-region-trigger]').forEach((trigger) => {
            trigger.addEventListener('click', openRegionSelector);
          });

          const regionNameFromSlug = (slug) => {
            const value = String(slug || '').trim();
            if (!value) return 'Madrid';
            const labels = {
              madrid: 'Madrid',
              facatativa: 'Facatativá',
              funza: 'Funza',
              'el-rosal': 'El Rosal',
              tocancipa: 'Tocancipá',
              chia: 'Chía',
              mosquera: 'Mosquera',
              sopo: 'Sopó',
              bojaca: 'Bojacá',
              cachipay: 'Cachipay',
            };
            if (labels[value]) return labels[value];
            return value
              .split('-')
              .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
              .join(' ');
          };

          const regionLabel = document.getElementById('current-region');
          const syncCurrentRegion = (slug) => {
            if (!regionLabel) return;
            regionLabel.textContent = regionNameFromSlug(slug);
          };

          syncCurrentRegion(localStorage.getItem('flowerxi_region') || 'madrid');
          window.addEventListener('regionchange', (event) => {
            syncCurrentRegion(event?.detail || localStorage.getItem('flowerxi_region') || 'madrid');
          });

          // Abrir chat
          document.getElementById('btn-chat')?.addEventListener('click', () => {
            window.dispatchEvent(new Event('openchat'));
          });

          // Refresh datos
          document.getElementById('btn-refresh')?.addEventListener('click', () => {
            window.__flowerxiForceFreshUntil = Date.now() + 1500;
            window.dispatchEvent(new Event('refreshdata'));
            window.dispatchEvent(new Event('flowerxi:refresh'));
          });
        }
      </script>
    </div>

    <style>
      /* App root */
      .app-root { min-height: 100vh; display: flex; flex-direction: column; }

      /* Topbar */
      .topbar {
        position: sticky; top: 0; z-index: 50;
        background: var(--bg-surface);
        border-bottom: 1px solid var(--border);
        padding: 0.75rem 1.5rem;
        display: flex; align-items: center; justify-content: space-between;
        gap: 1rem; box-shadow: var(--shadow);
      }
      .topbar-start { display: flex; align-items: center; gap: 1rem; min-width: 0; }
      .topbar-center { display: flex; justify-content: center; }
      .topbar-status {
        margin: 0;
        font-family: var(--font-sans);
        font-size: var(--text-lg);
        font-weight: var(--font-bold);
        line-height: var(--leading-tight);
        color: var(--text-primary);
      }
      .brand {
        font-family: var(--font-sans);
        font-weight: var(--font-bold);
        font-size: var(--text-2xl);
        color: var(--primary);
      }
      .topbar-end { display: flex; align-items: center; gap: 0.5rem; }
      .btn-icon {
        padding: 0.5rem; border: none; background: var(--bg-app);
        color: var(--text-secondary); border-radius: var(--radius);
        font-family: var(--font-sans);
        cursor: pointer; transition: all 150ms;
      }
      .btn-icon:hover { background: var(--border); color: var(--primary); }
      .btn-region-trigger {
        display: inline-flex; align-items: center; gap: 0.35rem;
        border: none; border-radius: 999px;
        background: var(--primary, #7b5ba6); color: #fff;
        padding: 0.46rem 0.72rem;
        font-family: var(--font-sans); font-size: var(--text-base); font-weight: var(--font-semibold);
        cursor: pointer;
      }
      .btn-region-trigger:hover { background: var(--primary-hover, #6b4f92); }
      .btn-region-trigger span { line-height: 1; }

      /* Region priority section */
      .region-priority {
        max-width: 1440px; margin: 0 auto; width: 100%;
        padding: 0.75rem 1.5rem 0.75rem;
        display: flex; align-items: center; justify-content: space-between;
        gap: 0.75rem;
      }
      .region-info-left { display: flex; flex-direction: column; gap: 0.1rem; }
      .region-priority-btn {
        border: 1px solid var(--primary, #7b5ba6); border-radius: 10px;
        background: color-mix(in srgb, var(--primary, #7b5ba6) 20%, var(--bg-surface, #fff));
        color: var(--primary, #7b5ba6);
        font-family: var(--font-sans); font-size: var(--text-base); font-weight: var(--font-semibold);
        padding: 0.52rem 0.75rem; cursor: pointer;
      }
      .region-current-label {
        margin: 0;
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        letter-spacing: 0.06em; text-transform: uppercase;
        color: var(--text-tertiary, #94a3b8);
      }
      .region-current-value {
        margin: 0;
        font-family: var(--font-sans);
        font-size: var(--text-4xl);
        line-height: 1.05; font-weight: var(--font-bold);
        color: var(--text-primary, #1f2937);
      }

      /* Layout principal */
      .main-layout { padding: 1.5rem; max-width: 1440px; margin: 0 auto; width: 100%; }
      .main-col { display: flex; flex-direction: column; gap: 1.5rem; }
      .hero-shell {
        display: grid;
        gap: 0.5rem;
      }
      .hero-shell-kicker {
        margin: 0;
        width: max-content;
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        font-weight: var(--font-semibold);
        color: #fff;
        border-radius: 999px;
        padding: 0.24rem 0.62rem;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-hover) 100%);
      }
      .hero-shell-sub {
        margin: -0.05rem 0 0.1rem;
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        color: var(--text-tertiary);
      }

      /* Dashboard 12 cols */
      .dashboard-12 { display: grid; grid-template-columns: repeat(12, 1fr); gap: 1.25rem; }
      .col-8 { grid-column: span 8; }
      .col-4 { grid-column: span 4; }
      .col-8, .col-4 {
        background: var(--bg-surface);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-lg);
        padding: 1.25rem;
        box-shadow: var(--shadow-sm);
      }
      @media (max-width: 1200px) {
        .dashboard-12 { grid-template-columns: 1fr; }
        .col-8, .col-4 { grid-column: span 1; }
      }

      .section-head {
        margin: 0 0 0.4rem 0;
        font-family: var(--font-sans);
        font-size: var(--text-xl);
        font-weight: var(--font-semibold);
        color: var(--text-primary);
      }
      .section-sub {
        margin: 0.2rem 0 0.8rem;
        font-family: var(--font-sans);
        font-size: var(--text-base);
        color: var(--text-tertiary);
      }

      /* Filas 2 columnas */
      .two-col-row {
        display: grid; grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.25rem;
      }
      .one-col-row {
        display: grid; grid-template-columns: 1fr;
        gap: 1.25rem;
      }

      .comparison-card {
        background: var(--bg-surface);
        border: 1px solid var(--border-subtle);
        border-radius: 14px; box-shadow: var(--shadow-sm);
        padding: 1.25rem; min-height: 520px;
        display: grid; gap: 0.75rem;
      }

      .station-card {
        background: var(--bg-surface);
        border: 1px solid var(--border-subtle);
        border-radius: 14px; box-shadow: var(--shadow-sm);
        padding: 1.25rem; display: grid; gap: 0.5rem;
      }
      .station-row { margin-top: 0.35rem; }
      .made-by {
        margin: 0.2rem 0 0;
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        color: var(--text-tertiary, #94a3b8);
      }

      /* Responsive móvil */
      @media (max-width: 1024px) {
        .two-col-row { grid-template-columns: 1fr; }
      }
      @media (max-width: 768px) {
        .main-layout { padding: 1rem; }
        .topbar { padding: 0.6rem 1rem; }
        .btn-region-trigger span { display: none; }
        .region-priority { padding: 0.65rem 1rem 0.65rem; }
        .hero-shell-sub { margin-top: 0; }
        .topbar-center { order: 3; width: 100%; justify-content: flex-start; }
        .topbar-end { flex: 1; justify-content: flex-end; }
        .dashboard-12 { gap: 1rem; }
      }
    </style>
  </body>
</html>
