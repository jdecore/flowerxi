---
import '../styles/index.css';
import RiskHero from '../islands/RiskHero.svelte';
import DailyAction from '../islands/DailyAction.svelte';
import WeatherMetrics from '../islands/WeatherMetrics.svelte';
import TrendChart from '../islands/TrendChart.svelte';
import WeeklyRecommendations from '../islands/WeeklyRecommendations.svelte';
import ChatBot from '../islands/ChatBot.svelte';
import RegionSelector from '../islands/RegionSelector.svelte';
import Sidebar from '../islands/Sidebar.svelte';

const apiUrl = import.meta.env.PUBLIC_API_URL ?? '';
const defaultRegion = 'madrid';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>flowerxi | Dashboard Agroclimático</title>
  </head>
  <body>
    <main class="dashboard-layout">
       <!-- Sidebar mejorado con labels -->
       <Sidebar {apiUrl} currentPath={Astro.url.pathname} client:load />

      <!-- Contenido principal -->
      <section class="main-content">
        <!-- Header con selector de región -->
        <header class="dashboard-header">
          <div class="header-left">
            <div class="logo-mark" aria-label="flowerxi">✿</div>
            <div>
              <h1>flowerxi</h1>
              <p class="subtitle">Vigilancia agroclimática para rosa de corte</p>
            </div>
          </div>
          <RegionSelector {apiUrl} currentRegion={defaultRegion} client:load />
        </header>

        <!-- HERO: Estado de riesgo (lo más importante) -->
        <section class="hero-section">
          <RiskHero {apiUrl} region={defaultRegion} client:load />
          <DailyAction {apiUrl} region={defaultRegion} client:load />
        </section>

        <!-- Panel de 3 columnas: métricas, gráfica, recomendaciones -->
        <section class="dashboard-grid">
          <WeatherMetrics {apiUrl} region={defaultRegion} client:load />
          <TrendChart {apiUrl} region={defaultRegion} client:load />
          <WeeklyRecommendations {apiUrl} region={defaultRegion} client:load />
        </section>
      </section>

      <!-- Chat IA -->
      <ChatBot {apiUrl} />
    </main>
  </body>
</html>

<style>
  .dashboard-layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 1.5rem;
    max-width: 1440px;
    margin: 0 auto;
    padding: 1.5rem;
    min-height: 100vh;
  }

  .main-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .dashboard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .logo-mark {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: grid;
    place-items: center;
    font-size: 1.5rem;
    color: white;
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
  }

  .header-left h1 {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 700;
    color: #1e293b;
    letter-spacing: -0.02em;
  }

  .subtitle {
    margin: 0.2rem 0 0;
    font-size: 0.85rem;
    color: #64748b;
  }

  .hero-section {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 1.25rem;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr 1fr;
    gap: 1.25rem;
  }

  @media (max-width: 1200px) {
    .dashboard-layout {
      grid-template-columns: 1fr;
      padding: 1rem;
    }

    .hero-section,
    .dashboard-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .dashboard-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .logo-mark {
      width: 40px;
      height: 40px;
      font-size: 1.25rem;
    }
  }
</style>
