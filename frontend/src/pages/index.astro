---
import EstadoOperativo from '../islands/EstadoOperativo.svelte';
import AccionDiaria from '../islands/AccionDiaria.svelte';
import MetricsClima from '../islands/MetricsClima.svelte';
import ChatBot from '../islands/ChatBot.svelte';
import '../styles/index.css';

const apiUrl = import.meta.env.PUBLIC_API_URL ?? '';
const defaultRegion = 'madrid';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>flowerxi | Estado de Cultivo</title>
  </head>
  <body>
    <main class="be-page">
      <section class="app-shell">
        <aside class="sidebar">
          <div class="sidebar-top">
            <div class="logo-mark" aria-label="flowerxi">✿</div>
            <nav class="sidebar-nav" aria-label="Navegacion principal">
              <a href="/" class="sidebar-icon active" aria-label="Inicio">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke="currentColor" aria-hidden="true">
                  <path d="M3 10.7L12 3l9 7.7" />
                  <path d="M5.5 9.7V21h13V9.7" />
                </svg>
              </a>
              <a href="/municipios" class="sidebar-icon" aria-label="Municipios">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke="currentColor" aria-hidden="true">
                  <path d="M12 21s7-5.6 7-11a7 7 0 10-14 0c0 5.4 7 11 7 11z" />
                  <circle cx="12" cy="10" r="2.8" />
                </svg>
              </a>
              <a href="/exportaciones" class="sidebar-icon" aria-label="Comercial">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke="currentColor" aria-hidden="true">
                  <path d="M21 12V7H5a2 2 0 010-4h14v4M3 5v14a2 2 0 002 2h16v-5M3 12h18" />
                </svg>
              </a>
              <a href="/estaciones" class="sidebar-icon" aria-label="Estaciones">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke="currentColor" aria-hidden="true">
                  <circle cx="12" cy="12" r="3" />
                  <path d="M12 2v4M12 18v4M2 12h4M18 12h4" />
                </svg>
              </a>
            </nav>
          </div>
          <div class="sidebar-bottom">
            <button class="sidebar-icon chat-toggle" aria-label="Chat AI">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" />
              </svg>
            </button>
          </div>
        </aside>

        <section class="main-panel">
          <header class="top-header">
            <div class="brand-block">
              <p class="brand-logo">flowerxi</p>
              <h1>Hola, cultivador. Esta es la prioridad operativa de tu cultivo hoy</h1>
            </div>
          </header>

          <section class="static-decision-grid">
            <article class="static-card">
              <p class="static-step">Marco de decisión</p>
              <h2>Riesgo = prioridad de atención hoy para el cultivo</h2>
              <p>
                No diagnostica plagas. Indica cuándo reforzar vigilancia y protocolos con base en clima reciente.
              </p>
            </article>

            <article class="static-card">
              <p class="static-step">Escala operativa</p>
              <div class="static-scale">
                <p><strong>Rutina:</strong> no hacer nada extra, mantener recorrido normal.</p>
                <p><strong>Vigilancia:</strong> revisar hoy humedad, drenaje y ventilación.</p>
                <p><strong>Acción:</strong> inspección en campo + registro fitosanitario + acción preventiva.</p>
              </div>
            </article>
          </section>

          <div class="islands-grid">
            <EstadoOperativo apiUrl={apiUrl} region={defaultRegion} client:load />
            <AccionDiaria apiUrl={apiUrl} region={defaultRegion} client:load />
            <MetricsClima apiUrl={apiUrl} region={defaultRegion} client:load />
          </div>
        </section>
      </section>
      <ChatBot client:idle />
    </main>

    <style>
      .islands-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
      }
      .islands-grid > :global(:last-child) {
        grid-column: 1 / -1;
      }
      @media (max-width: 1020px) {
        .islands-grid { grid-template-columns: 1fr; }
      }

      .static-decision-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
        margin-bottom: 1rem;
      }

      .static-card {
        background: linear-gradient(180deg, #302742 0%, #261d36 100%);
        border: 1px solid rgba(164, 127, 202, 0.3);
        border-radius: 18px;
        padding: 1.1rem 1.2rem;
        color: #f7f4ff;
      }

      .static-step {
        margin: 0;
        text-transform: uppercase;
        font-size: 0.74rem;
        letter-spacing: 0.07em;
        color: #bda6dc;
      }

      .static-card h2 {
        margin: 0.35rem 0 0;
        font-size: 1.05rem;
      }

      .static-card p {
        margin: 0.55rem 0 0;
        color: #e8ddf8;
        line-height: 1.4;
      }

      .static-scale p {
        margin-top: 0.45rem;
      }

      @media (max-width: 1020px) {
        .static-decision-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </body>
</html>
